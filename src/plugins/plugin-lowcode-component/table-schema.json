        },
        "columns": {
          "type": "JSExpression",
          "value": "[\n  { dataIndex: 'name', title: '姓名', width: 100 },\n  { dataIndex: 'age', title: '年龄', width: 80 },\n  { dataIndex: 'gender', title: '性别', width: 80 },\n  { dataIndex: 'phone', title: '电话', width: 130 },\n  { dataIndex: 'email', title: '邮箱', width: 180 },\n  { dataIndex: 'department', title: '部门', width: 100 },\n  { dataIndex: 'position', title: '职位', width: 120 }\n]"
        },
        "columnGroups": {
          "type": "JSExpression",
          "value": "[\n  { title: '基本信息', colSpan: 3, align: 'center' },\n  { title: '联系方式', colSpan: 2, align: 'center' },\n  { title: '工作信息', colSpan: 2, align: 'center' }\n]"
        }
      },
      "methods": {
        "getColumns": {
          "type": "JSFunction",
          "value": "function getColumns() {\n  const { columns, columnGroups } = this.state;\n  \n  // 如果没有分组配置，直接返回列配置\n  if (!columnGroups || columnGroups.length === 0) {\n    return columns;\n  }\n  \n  // 构建多级表头\n  const result = [];\n  let columnIndex = 0;\n  \n  columnGroups.forEach(group => {\n    const colSpan = group.colSpan || 1;\n    const groupConfig = {\n      title: group.title,\n      align: group.align || 'center',\n      children: []\n    };\n    \n    // 获取该组应该包含的列\n    for (let i = 0; i < colSpan && columnIndex < columns.length; i++) {\n      groupConfig.children.push(columns[columnIndex]);\n      columnIndex++;\n    }\n    \n    result.push(groupConfig);\n  });\n  \n  // 添加剩余未分组的列\n  while (columnIndex < columns.length) {\n    result.push(columns[columnIndex]);\n    columnIndex++;\n  }\n  \n  return result;\n}"
        },
        "updateDataSource": {
          "type": "JSFunction",
          "value": "function updateDataSource(newData) {\n  this.setState({\n    dataSource: newData\n  });\n}"
        },
        "updateColumns": {
          "type": "JSFunction",
          "value": "function updateColumns(newColumns) {\n  this.setState({\n    columns: newColumns\n  });\n}"
        },
        "updateColumnGroups": {
          "type": "JSFunction",
          "value": "function updateColumnGroups(newGroups) {\n  this.setState({\n    columnGroups: newGroups\n  });\n}"
        }
      },
